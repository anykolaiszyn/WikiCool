# GitHub repo that holds all wiki content (must be a separate private repo)
VITE_GITHUB_OWNER=your-github-username
VITE_GITHUB_REPO=vcc-wiki-content
VITE_GITHUB_BRANCH=main

# Root folder inside the content repo where markdown files live
VITE_CONTENT_PATH=content

# Optional: single-user homelab shortcut — paste a fine-grained PAT here.
# Leave blank in production; the app will prompt for a token at runtime instead.
VITE_GITHUB_TOKEN=

# Optional: base URL of the Cloudflare OAuth Worker (see oauth-worker/README.md).
# When set, the login screen shows a "Sign in with GitHub" button that triggers
# the OAuth flow instead of requiring a PAT to be pasted manually.
# Example: https://vcc-wiki-oauth.your-subdomain.workers.dev
VITE_OAUTH_BASE=

# Optional: base URL for the Worker's SSE stream (live-reload on push events).
# If your OAuth Worker and webhook Worker are the same deployment, set this to
# the same value as VITE_OAUTH_BASE. When set, the app subscribes to
# ${VITE_WEBHOOK_BASE}/events and automatically reloads content when the GitHub
# content repo receives a push.
# Example: https://vcc-wiki-oauth.your-subdomain.workers.dev
VITE_WEBHOOK_BASE=
